# ──────────────────────────────────────────────────────────────
#  Kitty · Matugen template — fully generated, zero config
#  Material You roles for UI · matugen's base16 palette for ANSI
#  Every value below is derived from the wallpaper.
#
#  Needs matugen ≥ 3.0 (base16 keywords + "lighten" filter)
# ──────────────────────────────────────────────────────────────

## Core
foreground              {{colors.on_surface.default.hex}}
background              {{colors.surface_container_lowest.default.hex}}

## Cursor
cursor                  {{colors.primary.default.hex}}
cursor_text_color       {{colors.on_primary.default.hex}}

## Selection
selection_background    {{colors.secondary_container.default.hex}}
selection_foreground    {{colors.on_secondary_container.default.hex}}

## URLs / links
url_color               {{colors.tertiary.default.hex}}

## Window borders
active_border_color     {{colors.primary.default.hex}}
inactive_border_color   {{colors.outline_variant.default.hex}}
bell_border_color       {{colors.error.default.hex}}

## Titlebar (Wayland / macOS)
wayland_titlebar_color  {{colors.surface_container_lowest.default.hex}}
macos_titlebar_color    {{colors.surface_container_lowest.default.hex}}

## Tab bar
tab_bar_background      {{colors.surface_container_lowest.default.hex}}
tab_bar_margin_color    {{colors.surface_container_lowest.default.hex}}
active_tab_foreground   {{colors.on_primary.default.hex}}
active_tab_background   {{colors.primary.default.hex}}
inactive_tab_foreground {{colors.on_surface_variant.default.hex}}
inactive_tab_background {{colors.surface_container_low.default.hex}}

## Marks
mark1_foreground        {{colors.on_primary.default.hex}}
mark1_background        {{colors.primary.default.hex}}
mark2_foreground        {{colors.on_secondary.default.hex}}
mark2_background        {{colors.secondary.default.hex}}
mark3_foreground        {{colors.on_tertiary.default.hex}}
mark3_background        {{colors.tertiary.default.hex}}

## ── ANSI 16 — from matugen's generated base16 palette ───────
## slot conventions: 08 red · 0A yellow · 0B green · 0C cyan ·
## 0D blue · 0E magenta
## Normals too hot on some walls? add "| lighten: -10.0"

## black
color0                  {{colors.surface_container.default.hex}}
color8                  {{colors.outline.default.hex}}

## red
color1                  {{base16.base08.default.hex}}
color9                  {{base16.base08.default.hex | lighten: 10.0}}

## green
color2                  {{base16.base0b.default.hex}}
color10                 {{base16.base0b.default.hex | lighten: 10.0}}

## yellow
color3                  {{base16.base0a.default.hex}}
color11                 {{base16.base0a.default.hex | lighten: 10.0}}

## blue
color4                  {{base16.base0d.default.hex}}
color12                 {{base16.base0d.default.hex | lighten: 10.0}}

## magenta
color5                  {{base16.base0e.default.hex}}
color13                 {{base16.base0e.default.hex | lighten: 10.0}}

## cyan
color6                  {{base16.base0c.default.hex}}
color14                 {{base16.base0c.default.hex | lighten: 10.0}}

## white
color7                  {{colors.on_surface_variant.default.hex}}
color15                 {{colors.on_surface.default.hex}}