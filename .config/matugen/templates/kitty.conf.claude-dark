# ──────────────────────────────────────────────────────────────
#  Kitty · Matugen template
#  Material You roles for UI + harmonized ANSI 16 palette
#
#  Requires the [config.custom_colors] block in matugen's
#  config.toml (red / green / yellow / blue / magenta / cyan).
#
#  matugen ≥ 3.0 — on matugen 2.x replace "lighten:" with
#  "set_lightness:"
# ──────────────────────────────────────────────────────────────

## Core
foreground              {{colors.on_surface.dark.hex}}
background              {{colors.surface_container_lowest.dark.hex}}

## Cursor
cursor                  {{colors.primary.dark.hex}}
cursor_text_color       {{colors.on_primary.dark.hex}}

## Selection
selection_background    {{colors.secondary_container.dark.hex}}
selection_foreground    {{colors.on_secondary_container.dark.hex}}

## URLs / links
url_color               {{colors.tertiary.dark.hex}}

## Window borders
active_border_color     {{colors.primary.dark.hex}}
inactive_border_color   {{colors.outline_variant.dark.hex}}
bell_border_color       {{colors.error.dark.hex}}

## Titlebar (Wayland / macOS)
wayland_titlebar_color  {{colors.surface_container_lowest.dark.hex}}
macos_titlebar_color    {{colors.surface_container_lowest.dark.hex}}

## Tab bar
tab_bar_background      {{colors.surface_container_lowest.dark.hex}}
tab_bar_margin_color    {{colors.surface_container_lowest.dark.hex}}
active_tab_foreground   {{colors.on_primary.dark.hex}}
active_tab_background   {{colors.primary.dark.hex}}
inactive_tab_foreground {{colors.on_surface_variant.dark.hex}}
inactive_tab_background {{colors.surface_container_low.dark.hex}}

## Marks
mark1_foreground        {{colors.on_primary.dark.hex}}
mark1_background        {{colors.primary.dark.hex}}
mark2_foreground        {{colors.on_secondary.dark.hex}}
mark2_background        {{colors.secondary.dark.hex}}
mark3_foreground        {{colors.on_tertiary.dark.hex}}
mark3_background        {{colors.tertiary.dark.hex}}

## ── ANSI 16 ─────────────────────────────────────────────────

## black
color0                  {{colors.surface_container.dark.hex}}
color8                  {{colors.outline.dark.hex}}

## red
color1                  {{colors.red.dark.hex}}
color9                  {{colors.red.dark.hex | lighten: 10.0}}

## green
color2                  {{colors.green.dark.hex}}
color10                 {{colors.green.dark.hex | lighten: 10.0}}

## yellow
color3                  {{colors.yellow.dark.hex}}
color11                 {{colors.yellow.dark.hex | lighten: 10.0}}

## blue
color4                  {{colors.blue.dark.hex}}
color12                 {{colors.blue.dark.hex | lighten: 10.0}}

## magenta
color5                  {{colors.magenta.dark.hex}}
color13                 {{colors.magenta.dark.hex | lighten: 10.0}}

## cyan
color6                  {{colors.cyan.dark.hex}}
color14                 {{colors.cyan.dark.hex | lighten: 10.0}}

## white
color7                  {{colors.on_surface_variant.dark.hex}}
color15                 {{colors.on_surface.dark.hex}}